# ============================================================
# File: .env.example
# Project: E-commerce User Behavior Data Platform
# Instructions: Copy this file to .env and fill in the actual 
#               values. NEVER commit the .env file to GitHub.
# ============================================================

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=ecommerce_dw

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
# Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# PySpark Configuration
SPARK_DRIVER_MEMORY=2g
SPARK_SHUFFLE_PARTITIONS=4

# Data Paths (Internal Docker Container Paths)
RAW_DATA_PATH=/opt/airflow/data/raw
OUTPUT_PATH=/opt/airflow/output
